# Copy to .env.local for local development (do not commit secrets).

# Optional — Google Analytics 4 measurement ID (public; defaults in `src/lib/analytics.ts` if unset)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Supabase (lead API uses service role; prefer SUPABASE_URL on server so Netlify runtime always sees it)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — Calendly booking URL (set in Netlify; never commit real URLs here)
NEXT_PUBLIC_CALENDLY_URL=

# Google reCAPTCHA v2 ("I'm not a robot" checkbox) — https://www.google.com/recaptcha/admin
# Register type: v2 → "I'm not a robot" Checkbox. Add your site domains.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

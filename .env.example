# Copy to .env.local for local development (do not commit secrets).

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — 30 min Calendly booking (default in code: mattf94856/30min)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/mattf94856/30min

# Google reCAPTCHA v2 ("I'm not a robot" checkbox) — https://www.google.com/recaptcha/admin
# Register type: v2 → "I'm not a robot" Checkbox. Add your site domains.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
